{
  "name": "inventory-service",
  "version": "1.0.0",
  "description": "Inventory management service with Redis caching and Kafka event streaming",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "inventory",
    "microservice",
    "kafka",
    "redis",
    "event-driven"
  ],
  "author": "Platform Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "kafkajs": "^2.2.4",
    "redis": "^4.6.8",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/cors": "^2.8.15",
    "@types/morgan": "^1.9.7",
    "@types/uuid": "^9.0.6",
    "@types/pg": "^8.10.7",
    "@types/node": "^20.8.7",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
